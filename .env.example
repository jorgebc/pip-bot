# pip-bot configuration
# Copy this file to .env and fill in the required values
# Required variables are marked with [REQUIRED]
# Optional variables are marked with [OPTIONAL]

# ============================================================================
# Phase 1: Bot Core & Raspberry Pi Control
# ============================================================================

# [REQUIRED] Discord bot token
# Get this from: https://discord.com/developers/applications
# 1. Create a new application
# 2. Go to "Bot" section and create a bot
# 3. Copy the token (treat it as a password, never commit it)
DISCORD_TOKEN=

# [REQUIRED] Discord server (guild) ID where bot will register commands
# Get this by:
# 1. Enable Developer Mode in Discord (User Settings > Advanced > Developer Mode)
# 2. Right-click your server and copy Server ID
DISCORD_GUILD_ID=

# [OPTIONAL] Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: INFO
# Use DEBUG for development, INFO for production
LOG_LEVEL=INFO

# [OPTIONAL] Discord channel ID where the bot sends a startup notification
# Get the channel ID by right-clicking the channel name (with Developer Mode enabled)
# STARTUP_CHANNEL_ID=

# ============================================================================
# Phase 1: Pi-hole Integration (optional)
# ============================================================================
# Required only for /pihole enable, /pihole disable, and /pihole top.
# /pihole status works without authentication.

# [OPTIONAL] Pi-hole host (default: localhost — use only if Pi-hole is on a different host)
# PIHOLE_HOST=localhost

# [OPTIONAL] Pi-hole HTTP port (default: 80)
# PIHOLE_PORT=80

# [OPTIONAL] Pi-hole web admin password
# Required for /pihole enable, /pihole disable, and /pihole top.
# This is the same password you use to log in to the Pi-hole web UI.
# The API token (double-MD5 hash) is derived from this automatically.
# PIHOLE_PASSWORD=

# ============================================================================
# Phase 2: NAS Control & Torrent Downloads (optional, not needed yet)
# ============================================================================
# NOTE: If you set NAS_HOST, you MUST set all four: NAS_HOST, NAS_PORT, NAS_USER, NAS_PASSWORD
# All-or-nothing validation is enforced by config/settings.py

# [OPTIONAL] NAS/Transmission host (IP address or hostname)
# Example: 192.168.1.100 or nas.local
# NAS_HOST=

# [OPTIONAL] Transmission RPC port
# Default Transmission RPC port is 9091
# NAS_PORT=9091

# [OPTIONAL] Transmission username
# NAS_USER=

# [OPTIONAL] Transmission password
# NAS_PASSWORD=

# ============================================================================
# Phase 3: External Agent Protocol — Discord → Email Bridge (optional)
# ============================================================================
# NOTE: If you set ACTIONS_CHANNEL_ID, you MUST also set ALLOWED_AGENT_IDS
# These variables enable external agents to send commands via a private Discord channel

# [OPTIONAL] Discord channel ID for external agent commands
# This channel should be private and only accessible to the bot and authorized agents
# Get the channel ID by right-clicking the channel name (with Developer Mode enabled)
# ACTIONS_CHANNEL_ID=

# [OPTIONAL] Comma-separated list of Discord user/bot IDs allowed to send agent commands
# Example: ALLOWED_AGENT_IDS=123456789012345678,987654321098765432
# Get user IDs by right-clicking their name (with Developer Mode enabled)
# ALLOWED_AGENT_IDS=

# [OPTIONAL] Email configuration (SMTP for sending reports)
# These will be fully documented when Phase 3 is implemented
# Common examples:
#   Gmail: smtp.gmail.com:587 with app password
#   Other services: check provider documentation
# SMTP_SERVER=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=
