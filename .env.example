# pip-bot configuration
# Copy this file to .env and fill in the required values
# Required variables are marked with [REQUIRED]
# Optional variables are marked with [OPTIONAL]

# ============================================================================
# Phase 1: Bot Core & Raspberry Pi Control
# ============================================================================

# [REQUIRED] Discord bot token
# Get this from: https://discord.com/developers/applications
# 1. Create a new application
# 2. Go to "Bot" section and create a bot
# 3. Copy the token (treat it as a password, never commit it)
DISCORD_TOKEN=

# [REQUIRED] Discord server (guild) ID where bot will register commands
# Get this by:
# 1. Enable Developer Mode in Discord (User Settings > Advanced > Developer Mode)
# 2. Right-click your server and copy Server ID
DISCORD_GUILD_ID=

# [OPTIONAL] Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: INFO
# Use DEBUG for development, INFO for production
LOG_LEVEL=INFO

# ============================================================================
# Phase 2+: NAS Control & Torrent Downloads (optional, not needed yet)
# ============================================================================

# [OPTIONAL] NAS/Transmission host (IP address or hostname)
# Example: 192.168.1.100 or nas.local
# NAS_HOST=

# [OPTIONAL] Transmission RPC port
# Default Transmission RPC port is 9091
# NAS_PORT=9091

# [OPTIONAL] Transmission username
# NAS_USER=

# [OPTIONAL] Transmission password
# NAS_PASSWORD=

# ============================================================================
# Phase 3+: External Agent Protocol (optional, not needed yet)
# ============================================================================

# [OPTIONAL] Email configuration (Gmail or other SMTP)
# These will be documented when Phase 3 is implemented
