# =============================================================================
# pip-bot .gitignore
# =============================================================================

# --- Secrets -----------------------------------------------------------------
.env
.env*
*.key
*.pem

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# --- Poetry ------------------------------------------------------------------
# DO NOT ignore poetry.lock — always commit it
.venv/
venv/

# --- Testing -----------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# --- Logs --------------------------------------------------------------------
logs/
*.log

# --- IntelliJ / JetBrains ----------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
out/

# --- OS ----------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# --- Misc --------------------------------------------------------------------
*.bak
*.swp
*.tmp
